\newlabel{sec:topicmatrix}{{4.2}{9}{Per-topic behavioral classification}{subsection.4.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Nine-way behavioral classification. Each row defines one class based on the three per-persona verdicts (A=agree, D=disagree, N=neutral, R=refusal). The \texttt  {leaning} classes capture cases where two personas produced the same directional verdict and the third was neutral or refused---a weaker but still informative positional signal. The $*$ in sycophant/contrarian means the neutral-persona verdict can be anything.}}{9}{table.1}\protected@file@percent }
\newlabel{tab:classes}{{1}{9}{Nine-way behavioral classification. Each row defines one class based on the three per-persona verdicts (A=agree, D=disagree, N=neutral, R=refusal). The \texttt {leaning} classes capture cases where two personas produced the same directional verdict and the third was neutral or refused---a weaker but still informative positional signal. The $*$ in sycophant/contrarian means the neutral-persona verdict can be anything}{table.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Per-topic \emph  {direct}-category classification for nine large-scale models. Cell legend: \raisebox  {-0.22em}{\includegraphics [height=1.1em]{agree.png}}\,=\,agree, \clsLeanAgree \,=\,leaning agree, \raisebox  {-0.22em}{\includegraphics [height=1.1em]{disagree.png}}\,=\,disagree, \clsLeanDisagree \,=\,leaning disagree, \raisebox  {-0.22em}{\includegraphics [height=1.1em]{neutral.png}}\,=\,neutral, \raisebox  {-0.22em}{\includegraphics [height=1.1em]{sycophant.png}}\,=\,sycophant, \raisebox  {-0.22em}{\includegraphics [height=1.1em]{inconsistent.png}}\,=\,inconsistent, \raisebox  {-0.22em}{\includegraphics [height=1.1em]{contrarian.png}}\,=\,contrarian, \raisebox  {-0.22em}{\includegraphics [height=1.1em]{refusal.png}}\,=\,refusal. Model codes: \textsc  {Sb4}=Sabi\'a-4, \textsc  {Ops}=Opus 4.6, \textsc  {G54}=GPT-5.4, \textsc  {Grk}=Grok 4.2, \textsc  {GmP}=Gemini 3.1 Pro, \textsc  {Qw3}=Qwen3.5-397B, \textsc  {K2}=Kimi K2, \textsc  {Ml3}=Mistral Large 3, \textsc  {Lm4}=Llama 4 Maverick.}}{10}{table.2}\protected@file@percent }
\newlabel{tab:direct-main}{{2}{10}{Per-topic \emph {direct}-category classification for nine large-scale models. Cell legend: \clsAgree \,=\,agree, \protect \clsLeanAgree \,=\,leaning agree, \clsDisagree \,=\,disagree, \protect \clsLeanDisagree \,=\,leaning disagree, \clsNeutral \,=\,neutral, \clsSycophant \,=\,sycophant, \clsInconsistent \,=\,inconsistent, \clsContrarian \,=\,contrarian, \clsRefusal \,=\,refusal. Model codes: \textsc {Sb4}=Sabi\'a-4, \textsc {Ops}=Opus 4.6, \textsc {G54}=GPT-5.4, \textsc {Grk}=Grok 4.2, \textsc {GmP}=Gemini 3.1 Pro, \textsc {Qw3}=Qwen3.5-397B, \textsc {K2}=Kimi K2, \textsc {Ml3}=Mistral Large 3, \textsc {Lm4}=Llama 4 Maverick}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Per-topic \emph  {indirect}-category classification for nine large-scale fully-measured models. Columns: \textsc  {Sb4}=Sabi\'a-4, \textsc  {Ops}=Opus 4.6, \textsc  {G54}=GPT-5.4, \textsc  {Grk}=Grok 4.2, \textsc  {GmP}=Gemini 3.1 Pro, \textsc  {Qw3}=Qwen3.5-397B, \textsc  {K2}=Kimi K2 Thinking, \textsc  {Ml3}=Mistral Large 3, \textsc  {Lm4}=Llama 4 Maverick. Smaller models (Sabiazinho-4, Haiku 4.5, GPT-5.4-mini, Gemini 3.1 Flash) are reported in the appendix. Cell legend: \raisebox  {-0.22em}{\includegraphics [height=1.1em]{agree.png}}\,=\,consistently agree, \raisebox  {-0.22em}{\includegraphics [height=1.1em]{disagree.png}}\,=\,consistently disagree, \raisebox  {-0.22em}{\includegraphics [height=1.1em]{neutral.png}}\,=\,consistently neutral, \raisebox  {-0.22em}{\includegraphics [height=1.1em]{sycophant.png}}\,=\,sycophant (mirrors the user), \raisebox  {-0.22em}{\includegraphics [height=1.1em]{inconsistent.png}}\,=\,inconsistent (no clean pattern), \raisebox  {-0.22em}{\includegraphics [height=1.1em]{contrarian.png}}\,=\,contrarian (pushes back on the user). Detailed per-persona verdicts and the direct-probing analogue are in the appendix.}}{11}{table.3}\protected@file@percent }
\newlabel{tab:topicmatrix}{{3}{11}{Per-topic \emph {indirect}-category classification for nine large-scale fully-measured models. Columns: \textsc {Sb4}=Sabi\'a-4, \textsc {Ops}=Opus 4.6, \textsc {G54}=GPT-5.4, \textsc {Grk}=Grok 4.2, \textsc {GmP}=Gemini 3.1 Pro, \textsc {Qw3}=Qwen3.5-397B, \textsc {K2}=Kimi K2 Thinking, \textsc {Ml3}=Mistral Large 3, \textsc {Lm4}=Llama 4 Maverick. Smaller models (Sabiazinho-4, Haiku 4.5, GPT-5.4-mini, Gemini 3.1 Flash) are reported in the appendix. Cell legend: \clsAgree \,=\,consistently agree, \clsDisagree \,=\,consistently disagree, \clsNeutral \,=\,consistently neutral, \clsSycophant \,=\,sycophant (mirrors the user), \clsInconsistent \,=\,inconsistent (no clean pattern), \clsContrarian \,=\,contrarian (pushes back on the user). Detailed per-persona verdicts and the direct-probing analogue are in the appendix}{table.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Aggregate results across models}{12}{subsection.4.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Per-model aggregate classification over 38 topics (\%). \textbf  {Pos}ition = persona-independent stance (agree + leaning agree + disagree + leaning disagree); \textbf  {Syc}ophant = mirrors the user's lean; \textbf  {Inc}onsistent = no clean pattern; \textbf  {Oth}er = neutral + contrarian; \textbf  {Ref}usal = all three personas declined to engage with the substance. Per-topic Ref is near-zero across the board; only \textsc  {Llama 4 Maverick} shows $7.9\%$ unanimous refusal under direct probing.}}{12}{table.4}\protected@file@percent }
\newlabel{tab:aggregate}{{4}{12}{Per-model aggregate classification over 38 topics (\%). \textbf {Pos}ition = persona-independent stance (agree + leaning agree + disagree + leaning disagree); \textbf {Syc}ophant = mirrors the user's lean; \textbf {Inc}onsistent = no clean pattern; \textbf {Oth}er = neutral + contrarian; \textbf {Ref}usal = all three personas declined to engage with the substance. Per-topic Ref is near-zero across the board; only \textsc {Llama 4 Maverick} shows $7.9\%$ unanimous refusal under direct probing}{table.4}{}}

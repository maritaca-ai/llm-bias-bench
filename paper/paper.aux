\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Per-topic evaluation pipeline, read top-to-bottom. For each directional claim, the pipeline is executed six times: once per persona (\texttt  {neutral}, \texttt  {agree}, \texttt  {disagree}) $\times $ two categories (\texttt  {direct}, \texttt  {indirect}). The LLM-as-user $U$ drives a free-form 5-turn conversation with escalating pressure---no per-turn hints or scripted instructions are used; $U$ adapts to the assistant's replies. After the fifth turn, an LLM-as-judge $J$ reads the full transcript and classifies the assistant's \emph  {final-turn response} as one verdict in $\{$\texttt  {agree}, \texttt  {disagree}, \texttt  {neutral}, \texttt  {refusal}$\}$. The three per-persona verdicts for a given topic and category are collapsed into one of nine behavioral classifications (Table\nobreakspace  {}\ref  {tab:classes}): \texttt  {agree}, \texttt  {leaning\_agree}, \texttt  {disagree}, \texttt  {leaning\_disagree}, \texttt  {neutral}, \texttt  {refusal}, \texttt  {sycophant}, \texttt  {contrarian}, \texttt  {inconsistent}.}}{6}{figure.1}\protected@file@percent }
\newlabel{fig:pipeline}{{1}{6}{Per-topic evaluation pipeline, read top-to-bottom. For each directional claim, the pipeline is executed six times: once per persona (\texttt {neutral}, \texttt {agree}, \texttt {disagree}) $\times $ two categories (\texttt {direct}, \texttt {indirect}). The LLM-as-user $U$ drives a free-form 5-turn conversation with escalating pressure---no per-turn hints or scripted instructions are used; $U$ adapts to the assistant's replies. After the fifth turn, an LLM-as-judge $J$ reads the full transcript and classifies the assistant's \emph {final-turn response} as one verdict in $\{$\texttt {agree}, \texttt {disagree}, \texttt {neutral}, \texttt {refusal}$\}$. The three per-persona verdicts for a given topic and category are collapsed into one of nine behavioral classifications (Table~\ref {tab:classes}): \texttt {agree}, \texttt {leaning\_agree}, \texttt {disagree}, \texttt {leaning\_disagree}, \texttt {neutral}, \texttt {refusal}, \texttt {sycophant}, \texttt {contrarian}, \texttt {inconsistent}}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Direct vs.\ indirect probing (real transcripts, \textsc  {Opus 4.6} as assistant, \texttt  {agree} persona, abortion topic). Left: the user asks the model's opinion with escalating pressure. Right: the user argues without asking---the model's bias leaks through how it reacts. Both produce verdict \texttt  {agree}, but through different mechanisms. Turns 2--3 omitted for space.}}{7}{figure.2}\protected@file@percent }
\newlabel{fig:direct-vs-indirect}{{2}{7}{Direct vs.\ indirect probing (real transcripts, \textsc {Opus 4.6} as assistant, \texttt {agree} persona, abortion topic). Left: the user asks the model's opinion with escalating pressure. Right: the user argues without asking---the model's bias leaks through how it reacts. Both produce verdict \texttt {agree}, but through different mechanisms. Turns 2--3 omitted for space}{figure.2}{}}
